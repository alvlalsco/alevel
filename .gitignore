# -----------------------------------------------------------------------------
# Node/npm Dependencies
# (Netlify will install these automatically on their servers)
# -----------------------------------------------------------------------------
node_modules/
package-lock.json      # Optional: Remove this line if you WANT to lock dependency versions

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# System Files (OS generated)
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# Environment Variables
# (Never commit API keys or secrets to GitHub!)
# -----------------------------------------------------------------------------
.env
.env.local
.env.development
.env.production

# -----------------------------------------------------------------------------
# Netlify Specific
# (Folders generated if you use the Netlify CLI locally)
# -----------------------------------------------------------------------------
.netlify/

# -----------------------------------------------------------------------------
# Compiled Build Output (Optional)
# -----------------------------------------------------------------------------
# If you want to keep your GitHub repo perfectly clean, you can ignore the 
# compiled Tailwind CSS file since Netlify generates it during the build step.
# Remove the '#' below to ignore it (update the path to match yours).
# 
# public/output.css