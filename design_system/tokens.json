{
  "$comment": "ALSCO Design System tokens. Machine-readable mirror of tokens.css (the source of truth). Keep both in sync — see design_system/README.md.",
  "color": {
    "primitive": {
      "maroon": "#88113b",
      "maroonDark": "#6d0d2f",
      "ink": "#1f2937",
      "white": "#ffffff",
      "black": "#000000",
      "gray700": "#374151",
      "gray300": "#d1d5db",
      "instagram": "#e1306c"
    },
    "semantic": {
      "primary": "#88113b",
      "primaryHover": "#6d0d2f",
      "onPrimary": "#ffffff",
      "bg": "#ffffff",
      "text": "#374151",
      "heading": "#1f2937",
      "border": "#d1d5db",
      "focusRing": "#88113b"
    }
  },
  "department": {
    "$comment": "Mirrors getDepartmentColor() in script.js; matched by substring. 'leadership' is also the default/fallback.",
    "leadership": { "bg": "#fee2e2", "text": "#b91c1c", "tailwind": "bg-red-100 text-red-700" },
    "welfare":    { "bg": "#dbeafe", "text": "#1d4ed8", "tailwind": "bg-blue-100 text-blue-700" },
    "relations":  { "bg": "#fce7f3", "text": "#be185d", "tailwind": "bg-pink-100 text-pink-700" },
    "comserve":   { "bg": "#dcfce7", "text": "#15803d", "tailwind": "bg-green-100 text-green-700" },
    "sst":        { "bg": "#fef3c7", "text": "#b45309", "tailwind": "bg-amber-100 text-amber-700" }
  },
  "font": {
    "sans": "'Outfit', ui-sans-serif, system-ui, sans-serif",
    "weight": {
      "light": 300,
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800,
      "black": 900
    },
    "leading": {
      "tight": 1.1,
      "normal": 1.5,
      "relaxed": 1.625
    }
  },
  "typography": {
    "scale": {
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem",
      "5xl": "3rem",
      "6xl": "3.75rem"
    },
    "roles": {
      "h1": { "weight": 900, "mobile": "2.25rem", "md": "3rem", "lg": "3.75rem", "fluid": "clamp(2.25rem, 1.5rem + 3.2vw, 3.75rem)", "transform": "none" },
      "h2": { "weight": 700, "mobile": "1.875rem", "md": "2.25rem", "lg": "3rem", "fluid": "clamp(1.875rem, 1.35rem + 2.2vw, 3rem)", "transform": "uppercase" },
      "h3": { "weight": 700, "mobile": "1.5rem", "md": "1.875rem", "lg": "1.875rem", "fluid": "clamp(1.5rem, 1.3rem + 0.9vw, 1.875rem)", "transform": "none" },
      "h4": { "weight": 700, "mobile": "1.125rem", "md": "1.5rem", "lg": "1.5rem", "fluid": "clamp(1.125rem, 1rem + 0.6vw, 1.5rem)", "transform": "none" },
      "body": { "weight": 400, "mobile": "0.875rem", "md": "1rem", "lg": "1.125rem", "fluid": "clamp(0.875rem, 0.8rem + 0.4vw, 1.125rem)", "leading": 1.625 }
    }
  },
  "radius": {
    "sm": "0.5rem",
    "card": "1.5rem",
    "pill": "9999px"
  },
  "spacing": {
    "sectionY": "4rem",
    "sectionYLg": "5rem",
    "gutter": "1.5rem",
    "gutterLg": "2rem"
  },
  "layout": {
    "container7xl": "80rem",
    "container6xl": "72rem"
  },
  "shadow": {
    "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "base": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)",
    "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)"
  },
  "motion": {
    "duration": "300ms",
    "durationSlow": "500ms",
    "ease": "cubic-bezier(0.4, 0, 0.2, 1)"
  },
  "focus": {
    "ringWidth": "2px",
    "ringOffset": "2px",
    "ringColor": "#88113b"
  },
  "breakpoints": {
    "$comment": "Tailwind defaults. Hover affordances are gated to lg and up (lg:hover:).",
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  }
}
